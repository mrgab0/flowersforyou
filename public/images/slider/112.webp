<style>
  .plans-wrap { max-width: 1100px; margin: 2.5rem auto 4rem; padding: 0 1rem; }
  .plans-wrap > h1 { text-align:center; font-size: 2.1rem; font-weight: 800;
                      color:#111827; margin: 0 0 .5rem; line-height: 1.2; }
  .plans-wrap > .sub { text-align: left; color:#4b5563; font-size: 1.05rem;
                        max-width: 820px; margin: 0 0 2rem; line-height: 1.55; }

  /* ── Billing-period toggle (monthly / annual) ── */
  .billing-toggle {
    display: inline-flex; background: #f3f4f6; border-radius: 999px;
    padding: .35rem; margin: 0 auto 2rem; gap: .25rem;
    position: relative;
  }
  .billing-toggle-wrap { text-align: center; }
  .billing-toggle button {
    padding: .55rem 1.5rem; border: none; background: transparent;
    border-radius: 999px; font-weight: 700; font-size: .92rem;
    color: #6b7280; cursor: pointer; transition: background .15s, color .15s;
    display: inline-flex; align-items: center; gap: .5rem;
  }
  .billing-toggle button.active { background: #1f2937; color: #fff; }
  .billing-save-pill {
    background: #dcfce7; color: #15803d;
    font-size: .7rem; padding: .12rem .45rem; border-radius: 999px;
    font-weight: 800; letter-spacing: .3px;
  }

  /* ── 3-column plan grid — centered, no shadows ── */
  .plans-grid {
    display: grid; gap: 1rem;
    grid-template-columns: repeat(3, 1fr);
    justify-content: center;            /* centre the row in its container */
    align-items: stretch;
  }

  .plan-card {
    background: #fff; border: 1px solid #e5e7eb; border-radius: 14px;
    padding: 2rem 1.5rem 1.75rem;       /* extra top padding so the badge
                                            sits inside the card, not clipped */
    display: flex; flex-direction: column;
    gap: 1rem; box-shadow: none; position: relative;
    box-sizing: border-box;
    overflow: visible;                  /* belt: badge can extend beyond if it
                                            ever needs to (currently doesn't) */
  }
  .plan-card.is-featured {
    border: 2px solid #2464c4;
    background: linear-gradient(180deg, #eff6ff 0%, #fff 30%);
    /* Slight scale-up on desktop so it visually anchors the page */
  }
  @media (min-width: 881px) {
    .plan-card.is-featured { transform: scale(1.02); z-index: 1; }
  }
  .plan-card.is-trial { background: #f9fafb; }

  /* Badge now lives INSIDE the top of the card (no negative top) — never
     clipped by parent overflow, never floats above. */
  .plan-badge-top {
    align-self: flex-start;
    background: #2464c4; color: #fff; font-size: .72rem; font-weight: 800;
    padding: .3rem .8rem; border-radius: 999px; letter-spacing: .4px;
    text-transform: uppercase; white-space: nowrap;
    margin: -.5rem 0 .25rem;            /* tuck slightly under top padding */
  }

  .plan-name { font-size: 1.05rem; font-weight: 800; color: #1f2937;
                margin: 0; letter-spacing: -.2px; }
  .plan-tagline { color: #6b7280; font-size: .85rem; margin: .25rem 0 0; line-height: 1.35; }
  .plan-price-row { margin: .5rem 0 .25rem; }
  .plan-price { font-size: 2.4rem; font-weight: 800; color: #111827; line-height: 1; }
  .plan-price small { font-size: 1rem; font-weight: 500; color: #6b7280; margin-left: .15rem; }
  .plan-billed { color: #6b7280; font-size: .8rem; margin: .35rem 0 0; min-height: 1.2em; }

  .plan-features { list-style: none; padding: 0; margin: .35rem 0 0; flex: 1 1 auto; }
  .plan-features li { padding: .35rem 0; color: #374151; font-size: .92rem;
                       display: flex; align-items: flex-start; gap: .5rem;
                       line-height: 1.4; }
  .plan-features li::before {
    content: '✓'; color: #10b981; font-weight: 800; flex-shrink: 0;
  }
  .plan-features li.muted { color: #9ca3af; }
  .plan-features li.muted::before { content: '○'; color: #9ca3af; font-weight: 500; }
  .plan-features li strong { color: #1f2937; }

  .plan-cta {
    display: block; text-align: center; padding: .9rem 1rem;
    border-radius: 10px; font-weight: 800; font-size: 1rem;
    text-decoration: none; border: none; cursor: pointer;
  }
  .plan-cta.cta-trial { background: #1f2937; color: #fff; }
  .plan-cta.cta-trial:hover { background: #111827; color: #fff; }
  .plan-cta.cta-pro { background: #2464c4; color: #fff; }
  .plan-cta.cta-pro:hover { background: #1d4ed8; color: #fff; }
  .plan-cta.cta-premium { background: #fbbf24; color: #1f2937; border: 2px dashed #f59e0b; }
  .plan-cta.cta-premium:hover { background: #f59e0b; color: #1f2937; }
  .plan-fineprint { color: #9ca3af; font-size: .75rem; text-align: center;
                     margin: .35rem 0 0; }

  /* ── Mobile carousel: middle card centered, peek of side cards, swipe.
        Mobile fonts dropped vs desktop so the page reads less shouty. ── */
  @media (max-width: 880px) {
    .plans-wrap > h1   { font-size: 1.4rem; line-height: 1.25; }
    .plans-wrap > .sub { font-size: .9rem; }
    .plan-name         { font-size: 1rem; }
    .plan-tagline      { font-size: .8rem; }
    .plan-price        { font-size: 2rem; }
    .plan-price small  { font-size: .85rem; }
    .plan-billed       { font-size: .72rem; }
    .plan-features li  { font-size: .85rem; padding: .25rem 0; }
    .plan-cta          { padding: .8rem 1rem; font-size: .95rem; }
    .billing-toggle button { padding: .5rem 1.1rem; font-size: .85rem; }
    .plan-badge-top    { font-size: .68rem; padding: .25rem .65rem; }

    .plans-grid {
      display: flex;
      grid-template-columns: none;
      overflow-x: auto; overflow-y: visible;
      scroll-snap-type: x mandatory;
      gap: .75rem;
      padding: 0 12vw 1rem;
      scroll-padding-inline: 12vw;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    .plans-grid::-webkit-scrollbar { display: none; }
    .plan-card {
      flex: 0 0 76vw;
      max-width: 360px;
      padding: 1.5rem 1.25rem 1.4rem;
      scroll-snap-align: center;
      scroll-snap-stop: always;
    }
    .plan-card.is-featured { transform: none; }
  }

  /* ── Carousel dots ── */
  .plans-dots {
    display: none; justify-content: center; gap: .5rem;
    margin: .5rem 0 1.5rem;
  }
  @media (max-width: 880px) { .plans-dots { display: flex; } }
  .plans-dots button {
    width: 8px; height: 8px; border-radius: 50%; border: none;
    background: #d1d5db; padding: 0; cursor: pointer;
    transition: background .15s, transform .15s;
  }
  .plans-dots button.active { background: #2464c4; transform: scale(1.4); }

  /* ── Trust strip — payment logos + secure connection ── */
  /* No grey background — the trust strip reads better as a plain centered
     row beneath the cards. Borderless keeps the focus on the payment
     logos instead of a chunky panel. */
  .plans-trust {
    margin: 2.5rem auto 0; padding: 1rem 0;
    display: flex; align-items: center; justify-content: center;
    gap: 1.5rem; flex-wrap: wrap;
    max-width: 720px;
  }
  .plans-trust-secure {
    display: inline-flex; align-items: center; gap: .5rem;
    color: #15803d; font-weight: 700; font-size: .88rem;
  }
  .plans-trust-secure svg { width: 18px; height: 18px; }
  .plans-trust-cards {
    display: inline-flex; align-items: center; gap: .5rem;
  }
  .plans-trust-cards img {
    height: 28px; width: auto; display: block;
    border-radius: 4px;
    /* Real brand logos already include their own padding/borders, so we
       don't double-up with a border + extra padding here. */
  }
  .plans-trust-text {
    color: #6b7280; font-size: .82rem; max-width: 220px; line-height: 1.4;
  }
  .plans-faq-line {
    text-align: center; color: #6b7280; font-size: .9rem; margin: 1.25rem 0 0;
  }
  .plans-faq-line a { color: #2464c4; text-decoration: none; }
</style>

  
  <style>
    /* Hard reset: kill the user-agent body margin (8px on most browsers)
       — that 8px showed up as a visible "header pushed down" gap on mobile. */
    html, body { margin: 0; padding: 0; max-width: 100vw; overflow-x: hidden; }
    @media (max-width: 760px) {
      img, video, picture, table, pre { max-width: 100%; height: auto; }
      .container, .content-row > .container { padding-left: 1rem; padding-right: 1rem; }
      /* iOS Safari auto-zooms the page when you focus an input whose
         font-size is < 16px. Force 16px on text form controls at mobile
         widths so tapping search / email / card fields doesn't trigger that
         jarring zoom. !important overrides the inline font-sizes some fields
         carry. Pinch-zoom stays enabled for accessibility. */
      input:not([type="checkbox"]):not([type="radio"]):not([type="range"]):not([type="color"]),
      select, textarea { font-size: 16px !important; }
    }
    /* Tier-scoped sidebar visibility — drives the data-tier="anon|premium"
       attribute on the sidebar root. Anon HTML is what the CDN caches; the
       bootstrap below flips the root attribute to "premium" for signed-in
       paying users without busting the cached HTML. */
    [data-sidebar-version] [data-tier-show="premium"] { display: none; }
    [data-sidebar-version][data-tier="premium"] [data-tier-show="premium"] { display: revert; }
    [data-sidebar-version][data-tier="premium"] [data-tier-show="anon"] { display: none; }
  </style>
  
  






  
  <script src="/static/js/wpc_fp.js" defer></script>
</head>
