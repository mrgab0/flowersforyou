          min-height: 44px !important;
          max-height: 44px !important;
        }
        main.page .plans-testi-track { align-items: center !important; }
        main.page figure.plans-testi-card {
          height: 34px !important;
          min-height: 34px !important;
          max-height: 34px !important;
          padding-top: 0 !important;
          padding-bottom: 0 !important;
          align-items: center !important;
        }
        main.page figure.plans-testi-card blockquote,
        main.page figure.plans-testi-card span {
          margin-top: 0 !important;
          margin-bottom: 0 !important;
          line-height: 1 !important;
        }

        /* Legacy wp-extras.css absolutely-positions every figcaption inside
           <main> (top:0/left:0/right:0, color:#fff) and reveals it on
           hover — built for the keyword-page tag overlay. Our testimonial
           cards reuse <figure>/<figcaption>, so without this override the
           credit line overlays the quote in the top-left as the marquee
           scrolls. Reset to static block flow. */
        .plans-testi-card { position: static; }
        .plans-testi-card figcaption,
        main figure.plans-testi-card:hover figcaption {
          position: static !important;
          display: block !important;
          color: #6b7280 !important;
          padding: 0 !important;
          pointer-events: auto !important;
        }
        @keyframes plans-testi-scroll {
          from { transform: translateX(0); }
          to   { transform: translateX(-50%); }
        }
        /* Pause only when hovering an actual card, not the gradient-mask
           edges (previous behavior paused on any section hover, which
           felt like the marquee mysteriously froze when the cursor
           wasn't even over a card). */
        .plans-testi-card:hover ~ .plans-testi-card,
        .plans-testi-track:has(.plans-testi-card:hover),
        .plans-testi-track:has(.plans-testi-card:focus-visible) {
          animation-play-state: paused;
        }
        .plans-testi-card:hover,
        .plans-testi-card:focus-visible {
          border-color: #cbd5e1;
          box-shadow: none;
          outline: none;
        }
        @media (prefers-reduced-motion: reduce) {
          .plans-testi-track { animation: none !important; }
        }
      </style>
